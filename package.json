{
  "name": "codeforce",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @codeforce/db generate",
    "db:migrate": "pnpm --filter @codeforce/db migrate"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
