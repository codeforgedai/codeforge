{
  "name": "codeforge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @codeforce/server dev",
    "dev:dashboard": "pnpm --filter @codeforce/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @codeforce/db generate",
    "db:migrate": "pnpm --filter @codeforce/db migrate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
